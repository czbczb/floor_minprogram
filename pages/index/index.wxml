<!--pages/index/index.wxml-->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <icon type="search" size="16" color="#999"/>
      <input 
        class="search-input" 
        placeholder="搜索地板产品" 
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 轮播图 - 热销产品 -->
  <view class="banner" wx:if="{{bannerProducts.length > 0}}">
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#fff" autoplay circular>
      <swiper-item wx:for="{{bannerProducts}}" wx:key="id" bindtap="onBannerTap" data-id="{{item._id || item.id}}">
        <view class="banner-item">
          <image class="banner-image" src="{{item.images[0]}}" mode="aspectFill"/>
          <view class="banner-info">
            <text class="banner-name">{{item.name}}</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>
  <view class="empty-banner" wx:else>
    <text>暂无热销产品</text>
  </view>

  <!-- 分类入口 -->
  <view class="category-grid">
    <view class="category-card" wx:for="{{categories}}" wx:key="id" bindtap="onCategoryTap" data-id="{{item._id}}">
      <image class="category-image" src="{{item.image}}" mode="aspectFill"/>
      <view class="category-name">{{item.name}}</view>
    </view>
  </view>

  <!-- 登录弹窗 -->
  <view class="login-modal-mask" wx:if="{{showLoginModal}}" bindtap="onCloseLoginModal"></view>
  <view class="login-modal" wx:if="{{showLoginModal}}">
    <view class="login-title">登录提示</view>
    <view class="login-content">查看产品详情需要先登录</view>
    <view class="login-buttons">
      <button class="login-cancel" bindtap="onCloseLoginModal">取消</button>
      <button class="login-confirm" bindtap="onDoLogin">立即登录</button>
    </view>
  </view>
</view>
