/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #0066CC;
  padding: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #ffffff;
  border-radius: 36rpx;
}

.search-input {
  flex: 1;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 10rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx !important;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #0066CC;
  font-size: 28rpx;
  margin-left: 20rpx;
  background-color: #ffffff;
  border-radius: 36rpx;
  padding: 0;
}

/* 区块标题 */
.section-title {
  padding: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* Banner轮播图 */
.banner {
  margin: 0 20rpx;
}

.banner-swiper {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.banner-name {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
}

.banner-price {
  color: #FF4D4F;
  font-size: 28rpx;
  font-weight: bold;
}

.empty-banner {
  margin: 0 20rpx;
  height: 300rpx;
  background-color: #e0e0e0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

/* 分类网格 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}

.category-card {
  width: calc(33.33% - 14rpx);
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  margin-right: 20rpx;
}

.category-card:nth-child(3n) {
  margin-right: 0;
}

.category-image {
  width: 100%;
  height: 200rpx;
  background-color: #F5F5F5;
}

.category-name {
  padding: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 查看更多 */
.view-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx;
  color: #0066CC;
  font-size: 28rpx;
}

.view-more .arrow {
  margin-left: 8rpx;
}

/* 登录弹窗 */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  z-index: 1001;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
}

.login-content {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-buttons {
  display: flex;
  justify-content: space-between;
}

.login-cancel,
.login-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 10rpx;
}

.login-cancel {
  background-color: #f5f5f5;
  color: #666666;
}

.login-confirm {
  background-color: #0066CC;
  color: #ffffff;
}
