/* pages/product/detail.wxss */
.swiper-container {
  position: relative;
  width: 100%;
  height: 750rpx;
  background-color: #F5F5F5;
}

.product-swiper {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.swiper-indicator {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.product-base {
  padding: 30rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.product-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.product-specs {
  padding: 30rpx;
}

.spec-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.spec-item:last-child {
  border-bottom: none;
}

.spec-name {
  width: 200rpx;
  font-size: 28rpx;
  color: #999999;
}

.spec-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.product-details {
  padding: 30rpx;
  padding-bottom: 120rpx;
}

.detail-images {
  display: flex;
  flex-direction: column;
}

.detail-image {
  width: 100%;
  display: block;
}

.loading {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
}

.empty-detail {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  border-top: 1rpx solid #E5E5E5;
  z-index: 100;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #666666;
}

.bar-item .icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.bar-item.contact {
  background-color: #0066CC;
  color: #ffffff;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
}

.modal-content {
  padding: 40rpx 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
}

.modal-actions {
  display: flex;
  border-top: 1rpx solid #E5E5E5;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 1rpx solid #E5E5E5;
}

.modal-btn.confirm {
  color: #0066CC;
}
