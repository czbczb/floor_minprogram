/* pages/product/manage.wxss */
.product-list {
  padding-bottom: 120rpx;
}

.product-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
}

.product-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #F5F5F5;
  margin-right: 20rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.product-category {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.product-price {
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.product-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 6rpx;
}

.action-btn.edit {
  background-color: #E3F2FD;
  color: #2196F3;
}

.action-btn.delete {
  background-color: #FFEBEE;
  color: #FF4D4F;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
}

.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
}

.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background-color: #1AAD19;
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(26, 173, 25, 0.3);
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal {
  width: 600rpx;
  max-height: 80vh;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-large {
  width: 90%;
  max-width: 700rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #E5E5E5;
  flex-shrink: 0;
}

.modal-content {
  flex: 1;
  padding: 30rpx;
  max-height: 60vh;
}

.modal-actions {
  display: flex;
  border-top: 1rpx solid #E5E5E5;
  flex-shrink: 0;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 1rpx solid #E5E5E5;
}

.modal-btn.confirm {
  color: #1AAD19;
}

/* 表单样式 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.spec-list {
  margin-bottom: 16rpx;
}

.spec-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.spec-remove {
  color: #FF4D4F;
  font-size: 32rpx;
  padding: 0 10rpx;
}

.spec-input {
  display: flex;
  gap: 10rpx;
}

.spec-input .input {
  flex: 1;
}

.spec-add-btn {
  width: 120rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #1AAD19;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-item.add {
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-item.add text {
  font-size: 60rpx;
  color: #999999;
}

.image-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 32rpx;
}

.image-item {
  position: relative;
}
