/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #0066CC;
  padding: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  background-color: #ffffff;
  border-radius: 36rpx;
}

.search-input {
  flex: 1;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 10rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx !important;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  color: #0066CC;
  font-size: 28rpx;
  margin-left: 20rpx;
  background-color: #ffffff;
  border-radius: 36rpx;
  padding: 0;
}

/* 搜索结果信息 */
.result-info {
  padding: 20rpx;
  font-size: 28rpx;
  color: #666666;
  display: flex;
  justify-content: space-between;
}

.result-count {
  color: #999999;
}

/* 产品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  margin-right: 20rpx;
}

.product-card:nth-child(2n) {
  margin-right: 0;
}

.product-image {
  width: 100%;
  height: 300rpx;
  background-color: #F5F5F5;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 28rpx;
  color: #FF4D4F;
  font-weight: bold;
}

.product-spec {
  font-size: 24rpx;
  color: #999999;
}

/* 空状态 */
.empty,
.init {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
  color: #999999;
  font-size: 28rpx;
}

/* 登录弹窗 */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  z-index: 1001;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
}

.login-content {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-buttons {
  display: flex;
  justify-content: space-between;
}

.login-cancel,
.login-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 10rpx;
}

.login-cancel {
  background-color: #f5f5f5;
  color: #666666;
}

.login-confirm {
  background-color: #0066CC;
  color: #ffffff;
}
