<!--pages/category/subcategory.wxml-->
<view class="container">
  <!-- 二级分类列表 -->
  <view class="sub-category-list">
    <view 
      class="sub-category-card" 
      wx:for="{{subCategories}}" 
      wx:key="_id"
      bindtap="onSubCategoryTap"
      data-id="{{item._id}}"
      data-name="{{item.name}}"
    >
      <view class="sub-category-content">
        <view class="sub-category-name">{{item.name}}</view>
        <view class="sub-category-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 产品列表 -->
  <view class="product-section" wx:if="{{products.length > 0}}">
    <view class="section-title">产品列表</view>
    <view class="product-list">
      <view 
        class="product-card" 
        wx:for="{{products}}" 
        wx:key="_id"
        bindtap="onProductTap"
        data-id="{{item._id}}"
      >
        <image 
          class="product-image" 
          src="{{item.images[0]}}" 
          mode="aspectFill"
        />
        <view class="product-info">
          <view class="product-name">{{item.name}}</view>
          <view class="product-desc" wx:if="{{item.description}}">{{item.description}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{subCategories.length === 0}}">
    <text>暂无子分类</text>
  </view>
</view>
