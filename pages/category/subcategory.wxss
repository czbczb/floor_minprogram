/* pages/category/subcategory.wxss */
.sub-category-list {
  padding: 20rpx;
}

.sub-category-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 102, 204, 0.1);
}

.sub-category-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}

.sub-category-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.sub-category-arrow {
  font-size: 40rpx;
  color: #0066CC;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  padding: 20rpx;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
}

.product-card {
  width: calc(50% - 10rpx);
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  margin-right: 20rpx;
}

.product-card:nth-child(2n) {
  margin-right: 0;
}

.product-image {
  width: 100%;
  height: 300rpx;
  background-color: #F5F5F5;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.product-desc {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
}
