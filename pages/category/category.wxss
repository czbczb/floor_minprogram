/* pages/category/category.wxss */
.container {
  display: flex;
  height: 100vh;
  background-color: #F5F5F5;
}

/* 左侧二级分类 */
.left-sidebar {
  width: 180rpx;
  height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  height: -webkit-calc(100vh - 80px);
  background-color: #ffffff;
}

.left-item {
  height: 100rpx;
  line-height: 100rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #666666;
  border-bottom: 1rpx solid #F5F5F5;
  display: flex;
  align-items: center;
}

.left-text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.left-item.active {
  background-color: #E3F2FD;
  color: #0066CC;
  font-weight: bold;
  border-left: 6rpx solid #0066CC;
}

/* 右侧内容区 */
.right-content {
  flex: 1;
  height: calc(100vh - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  height: -webkit-calc(100vh - 80px);
  display: flex;
  flex-direction: column;
}

.category-title {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  background-color: #ffffff;
  border-bottom: 1rpx solid #E5E5E5;
}

.product-scroll {
  flex: 1;
  padding: 20rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  padding-right: 40rpx;
}

/* 占满右侧宽度的产品card */
.product-card-full {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.product-image {
  width: 100%;
  height: 360rpx;
  background-color: #F5F5F5;
}

.product-info {
  padding: 30rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.product-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
}

/* 登录弹窗 */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 40rpx;
  z-index: 1001;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 20rpx;
}

.login-content {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 40rpx;
}

.login-buttons {
  display: flex;
  justify-content: space-between;
}

.login-cancel,
.login-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 10rpx;
}

.login-cancel {
  background-color: #f5f5f5;
  color: #666666;
}

.login-confirm {
  background-color: #0066CC;
  color: #ffffff;
}
